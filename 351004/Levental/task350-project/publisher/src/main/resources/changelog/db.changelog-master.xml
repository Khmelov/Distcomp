<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002-create-tbl-creator" author="openai">
        <createTable tableName="tbl_creator">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_tbl_creator" nullable="false"/>
            </column>
            <column name="login" type="VARCHAR(64)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_tbl_creator_login"/>
            </column>
            <column name="password" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="firstname" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="lastname" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="003-create-tbl-article" author="openai">
        <createTable tableName="tbl_article">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_tbl_article" nullable="false"/>
            </column>
            <column name="creator_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_tbl_article_creator"
                             referencedTableName="tbl_creator"
                             referencedColumnNames="id"/>
            </column>
            <column name="title" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="VARCHAR(2048)">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="modified" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="004-create-tbl-sticker" author="openai">
        <createTable tableName="tbl_sticker">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_tbl_sticker" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(32)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_tbl_sticker_name"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="005-create-tbl-notice" author="openai">
        <createTable tableName="tbl_notice">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_tbl_notice" nullable="false"/>
            </column>
            <column name="article_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_tbl_notice_article"
                             referencedTableName="tbl_article"
                             referencedColumnNames="id"/>
            </column>
            <column name="content" type="VARCHAR(2048)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="006-create-tbl-article-sticker" author="openai">
        <createTable tableName="tbl_article_sticker">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_tbl_article_sticker" nullable="false"/>
            </column>
            <column name="article_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_tbl_article_sticker_article"
                             referencedTableName="tbl_article"
                             referencedColumnNames="id"/>
            </column>
            <column name="sticker_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_tbl_article_sticker_sticker"
                             referencedTableName="tbl_sticker"
                             referencedColumnNames="id"/>
            </column>
        </createTable>

        <addUniqueConstraint
                tableName="tbl_article_sticker"
                columnNames="article_id, sticker_id"
                constraintName="uk_tbl_article_sticker_pair"/>
    </changeSet>
</databaseChangeLog>