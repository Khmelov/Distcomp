<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <changeSet id="1" author="rustam">
        <validCheckSum>ANY</validCheckSum>

        <createTable tableName="tbl_editor">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="login" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="firstname" type="VARCHAR(64)"/>
            <column name="lastname" type="VARCHAR(64)"/>
        </createTable>

        <createTable tableName="tbl_news">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="editor_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_news_editor" referencedTableName="tbl_editor" referencedColumnNames="id"/>
            </column>
            <column name="title" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="VARCHAR(2048)">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP"/>
            <column name="modified" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="tbl_sticker">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(32)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>

        <createTable tableName="tbl_news_sticker">
            <column name="news_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_ns_news" referencedTableName="tbl_news" referencedColumnNames="id"/>
            </column>
            <column name="sticker_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_ns_sticker" referencedTableName="tbl_sticker" referencedColumnNames="id"/>
            </column>
        </createTable>

        <createTable tableName="tbl_post">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="news_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_post_news" referencedTableName="tbl_news" referencedColumnNames="id"/>
            </column>
            <column name="content" type="VARCHAR(2048)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2-unique-title" author="rustam">
        <addUniqueConstraint
                columnNames="title"
                constraintName="uc_news_title"
                tableName="tbl_news"/>
    </changeSet>

</databaseChangeLog>