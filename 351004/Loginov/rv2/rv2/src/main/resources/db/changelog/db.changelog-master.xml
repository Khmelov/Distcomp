<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-distcomp-schema" author="codex">
        <sql dbms="postgresql">CREATE SCHEMA IF NOT EXISTS distcomp</sql>
    </changeSet>

    <changeSet id="002-create-tables" author="codex">
        <createTable tableName="tbl_writer">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="login" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="firstname" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="lastname" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="tbl_issue">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="writer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="content" type="VARCHAR(2048)">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="modified" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="tbl_comment">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="issue_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="VARCHAR(2048)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="tbl_tag">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(32)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>

        <createTable tableName="tbl_issue_tag">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="issue_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="tag_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="tbl_issue" baseColumnNames="writer_id"
                                 constraintName="fk_issue_writer"
                                 referencedTableName="tbl_writer" referencedColumnNames="id"
                                 onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="tbl_comment" baseColumnNames="issue_id"
                                 constraintName="fk_comment_issue"
                                 referencedTableName="tbl_issue" referencedColumnNames="id"
                                 onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="tbl_issue_tag" baseColumnNames="issue_id"
                                 constraintName="fk_issue_tag_issue"
                                 referencedTableName="tbl_issue" referencedColumnNames="id"
                                 onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="tbl_issue_tag" baseColumnNames="tag_id"
                                 constraintName="fk_issue_tag_tag"
                                 referencedTableName="tbl_tag" referencedColumnNames="id"
                                 onDelete="CASCADE"/>
        <addUniqueConstraint tableName="tbl_issue_tag" columnNames="issue_id, tag_id"
                             constraintName="uk_issue_tag_pair"/>
    </changeSet>

    <changeSet id="003-add-writer-role" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="tbl_writer" columnName="role"/>
            </not>
        </preConditions>
        <addColumn tableName="tbl_writer">
            <column name="role" type="VARCHAR(16)" defaultValue="CUSTOMER">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>
