<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

	<changeSet id="1" author="system">
		<createTable tableName="tbl_editor" remarks="Editor table">
			<column name="id" type="bigint" autoIncrement="true">
				<constraints primaryKey="true" nullable="false"/>
			</column>
			<column name="login" type="varchar(64)">
				<constraints nullable="false" unique="true"/>
			</column>
			<column name="password" type="varchar(128)">
				<constraints nullable="false"/>
			</column>
			<column name="firstname" type="varchar(64)">
				<constraints nullable="false"/>
			</column>
			<column name="lastname" type="varchar(64)">
				<constraints nullable="false"/>
			</column>
		</createTable>

		<addCheckConstraint
            tableName="tbl_editor"
            constraintName="ck_editor_login_length"
            condition="length(login) BETWEEN 2 AND 64"/>

		<addCheckConstraint
            tableName="tbl_editor"
            constraintName="ck_editor_password_length"
            condition="length(password) BETWEEN 8 AND 128"/>

		<addCheckConstraint
            tableName="tbl_editor"
            constraintName="ck_editor_firstname_length"
            condition="length(firstname) BETWEEN 2 AND 64"/>

		<addCheckConstraint
            tableName="tbl_editor"
            constraintName="ck_editor_lastname_length"
            condition="length(lastname) BETWEEN 2 AND 64"/>

		<createSequence sequenceName="tbl_editor_seq" startValue="1" incrementBy="1"/>
	</changeSet>
</databaseChangeLog>