<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

	<changeSet id="4" author="system">
		<createTable tableName="tbl_reaction">
			<column name="id" type="bigint" autoIncrement="true">
				<constraints primaryKey="true" nullable="false"/>
			</column>
			<column name="tweet_id" type="bigint">
				<constraints nullable="false"
                             foreignKeyName="fk_reaction_tweet"
                             references="tbl_tweet(id)"/>
			</column>
			<column name="content" type="varchar(2048)">
				<constraints nullable="false"/>
			</column>
		</createTable>

		<addCheckConstraint
            tableName="tbl_reaction"
            constraintName="ck_reaction_content_length"
            condition="length(content) BETWEEN 2 AND 2048"/>

		<createIndex tableName="tbl_reaction" indexName="idx_reaction_tweet">
			<column name="tweet_id"/>
		</createIndex>

		<createSequence sequenceName="tbl_reaction_seq" startValue="1" incrementBy="1"/>
	</changeSet>
</databaseChangeLog>