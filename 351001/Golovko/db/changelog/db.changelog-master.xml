<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="1" author="student">
        <sql>
            CREATE SCHEMA IF NOT EXISTS distcomp;
            ALTER DATABASE distcomp SET search_path TO distcomp, public;
        </sql>
    </changeSet>

    <changeSet id="2" author="student">
        <createTable schemaName="distcomp" tableName="tbl_editor">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="login" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="firstname" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="lastname" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="3" author="student">
        <createTable schemaName="distcomp" tableName="tbl_article">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="editor_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_article_editor" referencedTableName="tbl_editor" referencedTableSchemaName="distcomp" referencedColumnNames="id" deleteCascade="true"/>
            </column>
            <column name="title" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="content" type="VARCHAR(2048)">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="modified" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="4" author="student">
        <createTable schemaName="distcomp" tableName="tbl_tag">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(32)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="5" author="student">
        <createTable schemaName="distcomp" tableName="tbl_comment">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="article_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_comment_article" referencedTableName="tbl_article" referencedTableSchemaName="distcomp" referencedColumnNames="id" deleteCascade="true"/>
            </column>
            <column name="content" type="VARCHAR(2048)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="6" author="student">
        <createTable schemaName="distcomp" tableName="tbl_article_tag">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="article_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_articletag_article" referencedTableName="tbl_article" referencedTableSchemaName="distcomp" referencedColumnNames="id" deleteCascade="true"/>
            </column>
            <column name="tag_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_articletag_tag" referencedTableName="tbl_tag" referencedTableSchemaName="distcomp" referencedColumnNames="id" deleteCascade="true"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>